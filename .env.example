# Optional: Semantic Scholar API key for higher rate limits
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: GitHub token for higher rate limits on star counts
# GITHUB_TOKEN=

# Required for --share: deconstructedpapers.com API key
# DP_API_KEY=

# Optional: override deconstructedpapers.com base URL
# DP_BASE_URL=

# Optional: Reddit API credentials (not yet implemented)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
